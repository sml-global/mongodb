# Percona PSMDB operator user credentials.
# Copy this file to .local-dev-user-passwords.txt and fill in passwords.
# If you skip this step, scripts/bootstrap-dev-secrets.sh generates all values automatically.
#
# This file is NOT committed. .local-dev-user-passwords.txt is in .gitignore.
#
# Key                              | Purpose
# ---------------------------------|-----------------------------------------------
# MONGODB_BACKUP_USER              | Username for PBM backup agent (default: backup)
# MONGODB_BACKUP_PASSWORD          | Password for PBM backup agent
# MONGODB_CLUSTER_ADMIN_USER       | Username for replica set admin (default: clusterAdmin)
# MONGODB_CLUSTER_ADMIN_PASSWORD   | Password for replica set admin
# MONGODB_CLUSTER_MONITOR_USER     | Username for monitoring/health checks (default: clusterMonitor)
# MONGODB_CLUSTER_MONITOR_PASSWORD | Password for monitoring/health checks
# MONGODB_USER_ADMIN_USER          | Username for user management (default: userAdmin)
# MONGODB_USER_ADMIN_PASSWORD      | Password for user management
MONGODB_BACKUP_USER=backup
MONGODB_BACKUP_PASSWORD=CHANGE_ME
MONGODB_CLUSTER_ADMIN_USER=clusterAdmin
MONGODB_CLUSTER_ADMIN_PASSWORD=CHANGE_ME
MONGODB_CLUSTER_MONITOR_USER=clusterMonitor
MONGODB_CLUSTER_MONITOR_PASSWORD=CHANGE_ME
MONGODB_USER_ADMIN_USER=userAdmin
MONGODB_USER_ADMIN_PASSWORD=CHANGE_ME
